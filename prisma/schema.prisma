generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int      @id @default(autoincrement())
  name             String
  email            String   @unique
  password         String
  createdAt        DateTime @default(now())
  address          String?
  approved         Boolean  @default(false)
  experience       String?
  photo            String?
  specialist       String?
  technicianStatus String   @default("STANDBY")
  whatsapp         String?
  role             Role     @default(CUSTOMER)
  technicianOrders Order[]  @relation("TechnicianOrders")
}

model Order {
  id                Int      @id @default(autoincrement())
  customerName      String
  customerWhatsapp  String
  customerAddress   String
  service           String

  status            String   @default("PENDING")

  technicianId      Int?
  technician        Technician? @relation(fields: [technicianId], references: [id])

  createdAt         DateTime @default(now())
}

enum Role {
  ADMIN
  TECHNICIAN
  CUSTOMER
}

enum OrderStatus {
  PENDING
  ON_THE_WAY
  WORKING
  DONE
  CANCELLED
}

enum TechnicianStatus {
  OFFLINE
  STANDBY
  ON_THE_WAY
  WORKING
}
